{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nvpm.dev/client-config.schema.json",
  "title": "NVPM client config.yaml schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cache-dir": {
          "type": "string",
          "description": "Cache directory (used when NVPM_CACHE env var is not set). Supports absolute paths, ~, or paths relative to $HOME.",
          "minLength": 1
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "urls": {
          "type": "array",
          "description": "Registry zip URLs. Gets merged. Later entries take precedence over earlier ones.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "cache-max-age": {
          "type": "string",
          "description": "How long the downloaded registry zip is considered fresh. Go duration string (e.g. 30m, 6h, 24h, 0).",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h|d)$|^0$"
        },
        "min-release-age": {
          "type": "string",
          "description": "Minimum age before installing/updating a newly discovered version. Uses local discovery time (not upstream timestamps). Go duration string (e.g. 7d, 168h, 0).",
          "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h|d)$|^0$"
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "string",
          "description": "When to use colors/icons.",
          "enum": ["auto", "always", "never"]
        },
        "output": {
          "type": "string",
          "description": "Output format.",
          "enum": ["rich", "plain", "json"]
        }
      }
    }
  }
}

